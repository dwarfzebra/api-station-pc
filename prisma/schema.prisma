generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// 1. API 分组：基于域名
model ApiGroup {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  testUrl     String?  @db.VarChar(255) // 测试域名
  prodUrl     String?  @db.VarChar(255) // 生产域名
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apis        ApiDefinition[]
}

// 2. API 定义：属于某个分组
model ApiDefinition {
  id            Int      @id @default(autoincrement())
  groupId       Int
  name          String   @db.VarChar(255)
  method        String   @db.VarChar(20) // GET, POST, PUT, DELETE...
  path          String   @db.VarChar(255)
  reqHeaders    Json?    // 接口私有的 Headers
  reqQuery      Json?    
  reqBodyType   String?  @db.VarChar(50) 
  reqBody       Json?    // 请求体结构，改为 Json 以支持表格编辑
  resBody       Json?    // 响应体结构与注释
  preScript     String?  @db.Text 
  postScript    String?  @db.Text 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  apiGroup      ApiGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

// 3. 业务场景：工作流的容器
model WorkflowScene {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflows    Workflow[]
}

// 4. 工作流：属于某个场景
model Workflow {
  id          Int      @id @default(autoincrement())
  sceneId     Int
  name        String   @db.VarChar(255)
  description String?  @db.Text
  steps       Json?    // 线性步骤集合: [ { id, apiId, mappingConfig } ]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scene       WorkflowScene  @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  runs        WorkflowRun[]
}

// 5. 链路运行记录
model WorkflowRun {
  id          Int      @id @default(autoincrement())
  workflowId  Int
  status      String   @db.VarChar(20) // RUNNING, SUCCESS, FAIL
  startTime   DateTime @default(now())
  endTime     DateTime?
  duration    Int?     // 总耗时ms

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  apiLogs     ApiRunLog[]
}

// 6. API 运行日志 (单次调用详情)
model ApiRunLog {
  id            Int      @id @default(autoincrement())
  workflowRunId Int?     // 可选：如果是在链路中运行的，则关联链路运行 ID
  apiId         Int
  apiName       String   @db.VarChar(255)
  method        String   @db.VarChar(20)
  url           String   @db.Text
  reqHeaders    Json?
  reqQuery      Json?
  reqBody       Json?
  resStatus     Int?
  resHeaders    Json?
  resBody       Json?
  duration      Int?     // 耗时ms
  error         String?  @db.Text
  createdAt     DateTime @default(now())

  workflowRun   WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
}
